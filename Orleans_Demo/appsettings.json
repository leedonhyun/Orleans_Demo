{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Orleans": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MyDatabase": "Host=localhost;Port=6432;Database=postgres;Username=postgres;Password=password;Include Error Detail=true"
  },
  "SignalR": {
    "Orleans": {
      "ConnectionPartitionCount": 4,
      "GroupPartitionCount": 4,
      "ConnectionsPerPartitionHint": 10000,
      "GroupsPerPartitionHint": 1000,
      "KeepEachConnectionAlive": true,
      "ClientTimeoutIntervalSeconds": 30,
      "KeepMessageIntervalSeconds": 66
    },
    "Redis": {
      "Enabled": true,
      "ConnectionString": "localhost:6379,abortConnect=false"
    }
  },
  "AllowedHosts": "*"
}
